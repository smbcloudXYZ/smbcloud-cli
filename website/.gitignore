# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# nextra search index (pagefind)
/public/_pagefind/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
.env*.local

# vercel
.vercel

# Developer docs generated from ../docs by scripts/generate-developer-docs.mjs
# (run on predev/prebuild). ../docs is the source of truth; index.mdx is hand-written.
/content/developer/_meta.js
/content/developer/cli/_meta.js
/content/developer/cli/native.mdx
/content/developer/cli/homebrew.mdx
/content/developer/cli/npm.mdx
/content/developer/cli/pypi.mdx
/content/developer/cli/interfaces.mdx
/content/developer/cli/mcp.mdx
/content/developer/cli/ci.mdx
/content/developer/contributing/_meta.js
/content/developer/contributing/debugging.mdx
/content/developer/contributing/development.mdx
/content/developer/contributing/gems.mdx
