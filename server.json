{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.smbcloudXYZ/smbcloud-cli",
  "title": "smbCloud Mail & Auth",
  "description": "Email infrastructure and authentication for developers: domains, inbox routes, auth apps, deploys.",
  "version": "0.4.13",
  "websiteUrl": "https://docs.smbcloud.xyz/developer/cli",
  "icons": [
    {
      "src": "https://smbcloud.xyz/logo.png",
      "mimeType": "image/png",
      "sizes": ["866x866"]
    }
  ],
  "repository": {
    "url": "https://github.com/smbcloudXYZ/smbcloud-cli",
    "source": "github",
    "id": "597171611"
  },
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@smbcloud/cli",
      "version": "0.4.13",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "named",
          "name": "--mcp",
          "description": "Run the CLI as an MCP server over stdio instead of executing a one-shot command.",
          "isRequired": true
        }
      ]
    },
    {
      "registryType": "nuget",
      "registryBaseUrl": "https://api.nuget.org/v3/index.json",
      "identifier": "SmbCloud.Cli",
      "version": "0.4.13",
      "runtimeHint": "dnx",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "named",
          "name": "--mcp",
          "description": "Run the CLI as an MCP server over stdio instead of executing a one-shot command.",
          "isRequired": true
        }
      ]
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "categories": ["email", "authentication", "developer-tools"],
      "keywords": [
        "transactional email",
        "email api",
        "email domains",
        "inbox routing",
        "authentication",
        "oauth",
        "identity",
        "deployment"
      ],
      "products": {
        "smbCloud Mail": "https://smbcloudmail.com",
        "smbCloud Auth": "https://smbcloudauth.com"
      }
    }
  }
}
